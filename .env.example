# AeroAPI (FlightAware) — for fetch_flights.js
# Get a key at https://www.flightaware.com/aeroapi/portal/
AEROAPI_KEY=your_aeroapi_key_here

# Google Maps / Routes API — for fetch_drive_times.js
# Enable the Routes API in Google Cloud Console and create an API key
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
